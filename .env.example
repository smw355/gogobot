# Gogobot - Single-Tenant Self-Hosted AI Code Builder
# Copy this file to .env.local and fill in the values

# ===========================================
# Firebase Client (Public - safe to expose)
# ===========================================
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# ===========================================
# Firebase Admin (Server-side only - KEEP SECRET)
# ===========================================
# JSON string of service account key (single line)
FIREBASE_ADMIN_KEY={"type":"service_account","project_id":"your-project",...}

# ===========================================
# Google Cloud Platform
# ===========================================
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Billing account ID for per-project GCP provisioning
# Required to create isolated GCP projects for each Gogobot project
GCP_BILLING_ACCOUNT_ID=01XXXX-XXXXXX-XXXXXX

# Gogobot folder ID — org admin creates this folder and grants SA access
# All user sub-folders and projects are created inside this folder
# See CLAUDE.md "GCP Folder Setup" for instructions
GCP_FOLDER_ID=your-folder-id

# ===========================================
# Application
# ===========================================
# IMPORTANT: Set this to your production URL when deploying (used for invite links, password reset, etc.)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NODE_ENV=development

# ===========================================
# Optional: AI Model Configuration
# ===========================================
# Override the default Gemini models (useful when preview models rotate)
# AI_PRIMARY_MODEL=gemini-3.1-pro-preview
# AI_FALLBACK_MODEL=gemini-3-flash-preview
# AI_PRIMARY_LOCATION=global
# AI_FALLBACK_LOCATION=global

# ===========================================
# Optional: Regional Configuration
# ===========================================
# Override default locations for child project resources
# GCP_FIRESTORE_LOCATION=nam5
# GCP_STORAGE_LOCATION=US

# Custom Cloud Storage bucket for user-uploaded assets (default: {PROJECT_ID}-assets)
# GCP_ASSETS_BUCKET=my-custom-assets-bucket

# ===========================================
# Optional: Instance Configuration
# ===========================================
# GOGOBOT_INSTANCE_NAME=My Company Builder
